filters:
  and:
    - arch.contains("#5note")
    - archtype.contains("#5note/5evergreen")
    - inbox != true
    - status != "archive"
    - status != "archived"
    - status != "bin"
    - status != "canceled"
views:
  - type: table
    name: Evergreen
    order:
      - LID
      - file.name
      - status
      - science
      - discipline
      - file.mtime
      - file.path
    sort:
      - property: file.mtime
        direction: DESC
    columnSize:
      note.LID: 90
      file.name: 260
      note.status: 90
      note.science: 130
      note.discipline: 130
      file.mtime: 120
