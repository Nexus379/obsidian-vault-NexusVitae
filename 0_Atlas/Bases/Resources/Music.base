filters:
  and:
    - arch.contains("#6resou")
    - archtype.contains("#6resou/music")
views:
  - type: table
    name: Music
    order:
      - cover
      - file.name
      - creator
      - plattform
      - status
      - rating
      - url
      - file.path
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      cover: 90
      file.name: 240
      note.creator: 160
      note.plattform: 120
      note.status: 90
