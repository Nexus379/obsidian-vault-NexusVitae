filters:
  and:
    - arch.contains("#2area")
    - archtype.contains("#2area/2relationship")
    - inbox != true
    - status != "archive"
    - status != "archived"
    - status != "bin"
    - status != "canceled"
views:
  - type: table
    name: Relationship
    order:
      - file.name
      - status
      - priority
      - file.mtime
      - file.path
    sort:
      - property: file.mtime
        direction: DESC
    columnSize:
      file.name: 260
      note.status: 90
      note.priority: 70
      file.mtime: 120

