filters:
  and:
    - arch.contains("#6resou")
    - archtype.contains("#6resou/recipe")
views:
  - type: table
    name: Recipes
    order:
      - cover
      - file.name
      - status
      - rating
      - area2
      - note5
      - file.path
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      cover: 90
      file.name: 240
      note.status: 90
      note.rating: 80
