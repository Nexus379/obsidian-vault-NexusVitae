filters:
  and:
    - arch.contains("#6resou")
    - archtype.contains("#6resou/boardgame")
views:
  - type: table
    name: Boardgame
    order:
      - cover
      - file.name
      - creator
      - status
      - rating
      - area2
      - file.path
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      cover: 90
      file.name: 240
      note.creator: 160
      note.status: 90
      note.rating: 80
