filters:
  and:
    - arch.contains("#6resou")
    - archtype.contains("#6resou/ai")
views:
  - type: table
    name: AI
    order:
      - cover
      - file.name
      - plattform
      - status
      - rating
      - url
      - discipline
      - science
      - file.path
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      cover: 90
      file.name: 240
      note.plattform: 120
      note.status: 90
      note.rating: 80
